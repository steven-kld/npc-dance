[
    {
        "id": "abs142",
        "name": "Fill Demo",
        "description": "Fill one or more payment drafts in the Demo Bank form",
        "start_url": "http://localhost:8000/demo",
        "input_schema": [
            {
                "key": "full_name",
                "description": "Recipient full name"
            },
            {
                "key": "iban",
                "description": "Recipient IBAN, no spaces"
            },
            {
                "key": "bic_swift",
                "description": "Recipient bank BIC or SWIFT code"
            },
            {
                "key": "intermediary_bic",
                "description": "Intermediary bank BIC (if any)",
                "optional": true
            },
            {
                "key": "full_address",
                "description": "Recipient address"
            },
            {
                "key": "amount",
                "description": "Transfer amount"
            }
        ],
        "steps": [
            {
                "type": "navigate",
                "url": "http://localhost:8000/demo"
            },
            {
                "type": "click and paste",
                "search_description": "Full Name input field",
                "input_text": "{full_name.value}"
            },
            {
                "type": "click and paste",
                "search_description": "IBAN input field",
                "input_text": "{iban.value}"
            },
            {
                "type": "click and paste",
                "search_description": "BIC / SWIFT input field",
                "input_text": "{bic_swift.value}"
            },
            {
                "type": "click and paste",
                "search_description": "Intermediary BIC input field",
                "input_text": "{intermediary_bic.value}"
            },
            {
                "type": "click and paste",
                "search_description": "Full Address input field",
                "input_text": "{full_address.value}"
            },
            {
                "type": "click and paste",
                "search_description": "Amount input field",
                "input_text": "{amount.value}"
            },
            {
                "type": "click",
                "search_description": "Submit button"
            },
            {
                "type": "wait sec",
                "seconds": 2
            },
            {
                "type": "click",
                "search_description": "Add one more button"
            }
        ]
    }
]
